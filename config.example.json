{
  "dashboard": {
    "host": "0.0.0.0",
    "port": 8088,
    "default_mode": "clock",
    "clock_format": "24h",
    "idle_timeout_seconds": 180,
    "night_dim_start": "02:00",
    "night_dim_end": "11:00"
  },
  "plexamp": {
    "url": "http://localhost:32500",
    "pause_url": "http://localhost:32500/player/playback/pause",
    "service_name": "plexamp.service"
  },
  "airplay": {
    "display_name": "Bedroom Plexamp"
  },
  "display": {
    "x_display": ":0",
    "xauthority": "/home/andy/.Xauthority",
    "browser_command": "chromium-browser",
    "dashboard_url": "http://localhost:8088",
    "airplay_url": "http://localhost:8088/airplay",
    "clock_url": "http://localhost:8088/clock",
    "weather_url": "http://localhost:8088/weather",
    "plexamp_url": "http://localhost:32500"
  },
  "weather": {
    "provider": "ecowitt_push",
    "display_units": "metric",
    "station_name": "Weather or Not",
    "reporting_station_name": "Weather Station Name",
    "auto_refresh_seconds": 60,
    "units": {
      "temperature": "c",
      "pressure": "hpa",
      "rain": "mm",
      "wind": "mph"
    },
    "clock_cards": [
      "outdoor_temp",
      "humidity",
      "wind_speed",
      "wind_gust",
      "daily_rain",
      "pressure"
    ]
  },
  "alarm": {
    "enabled": false,
    "default_time": "11:00",
    "snooze_minutes": 8,
    "schema_version": 2,
    "defaults": {
      "snooze_minutes": 8,
      "ring_minutes": 3,
      "occurrence_expiry_minutes": 120,
      "tone_id": "classic-klaxon",
      "fallback_tone_id": "emergency-buzzer",
      "source_type": "tone"
    },
    "alarms": [
      {
        "id": "default-alarm",
        "enabled": false,
        "label": "Default alarm",
        "time": "11:00",
        "days": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"],
        "snooze_minutes": 8,
        "ring_minutes": 3,
        "occurrence_expiry_minutes": 120,
        "source": {
          "type": "tone",
          "tone_id": "classic-klaxon",
          "fallback_tone_id": "emergency-buzzer"
        },
        "volume": {
          "start_percent": 60,
          "target_percent": 85,
          "fade_seconds": 10
        }
      }
    ]
  }
}
